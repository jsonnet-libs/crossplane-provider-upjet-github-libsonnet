          withMinEntriesToMerge(minEntriesToMerge): { minEntriesToMerge: minEntriesToMerge },
          '#withMinEntriesToMergeWaitMinutes':: d.fn(help='"(Number) The time merge queue should wait after the first PR is added to the queue for the minimum group size to be met. After this time has elapsed, the minimum group size will be ignored and a smaller group will be merged. Defaults to 5.\\nThe time merge queue should wait after the first PR is added to the queue for the minimum group size to be met. After this time has elapsed, the minimum group size will be ignored and a smaller group will be merged. Defaults to `5`."', args=[d.arg(name='minEntriesToMergeWaitMinutes', type=d.T.integer)]),
          withMinEntriesToMergeWaitMinutes(minEntriesToMergeWaitMinutes): { minEntriesToMergeWaitMinutes: minEntriesToMergeWaitMinutes },
