        '#pullRequest':: d.obj(help='"(Block List, Max: 1) Require all commits be made to a non-target branch and submitted via a pull request before they can be merged. (see below for nested schema)\\nRequire all commits be made to a non-target branch and submitted via a pull request before they can be merged."'),
        pullRequest: {
          '#withDismissStaleReviewsOnPush':: d.fn(help='"(Boolean) New, reviewable commits pushed will dismiss previous pull request review approvals. Defaults to false.\\nNew, reviewable commits pushed will dismiss previous pull request review approvals. Defaults to `false`."', args=[d.arg(name='dismissStaleReviewsOnPush', type=d.T.boolean)]),
          withDismissStaleReviewsOnPush(dismissStaleReviewsOnPush): { dismissStaleReviewsOnPush: dismissStaleReviewsOnPush },
