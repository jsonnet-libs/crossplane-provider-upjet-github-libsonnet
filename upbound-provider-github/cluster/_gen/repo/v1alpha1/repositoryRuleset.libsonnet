        '#mergeQueue':: d.obj(help='"(Block List, Max: 1) Merges must be performed via a merge queue.\\nMerges must be performed via a merge queue."'),
        mergeQueue: {
          '#withCheckResponseTimeoutMinutes':: d.fn(help='"(Number)Maximum time for a required status check to report a conclusion. After this much time has elapsed, checks that have not reported a conclusion will be assumed to have failed. Defaults to 60.\\nMaximum time for a required status check to report a conclusion. After this much time has elapsed, checks that have not reported a conclusion will be assumed to have failed. Defaults to `60`."', args=[d.arg(name='checkResponseTimeoutMinutes', type=d.T.integer)]),
          withCheckResponseTimeoutMinutes(checkResponseTimeoutMinutes): { checkResponseTimeoutMinutes: checkResponseTimeoutMinutes },
          '#withGroupingStrategy':: d.fn(help='"(String)When set to ALLGREEN, the merge commit created by merge queue for each PR in the group must pass all required checks to merge. When set to HEADGREEN, only the commit at the head of the merge group, i.e. the commit containing changes from all of the PRs in the group, must pass its required checks to merge. Can be one of: ALLGREEN, HEADGREEN. Defaults to ALLGREEN.\\nWhen set to ALLGREEN, the merge commit created by merge queue for each PR in the group must pass all required checks to merge. When set to HEADGREEN, only the commit at the head of the merge group, i.e. the commit containing changes from all of the PRs in the group, must pass its required checks to merge. Can be one of: ALLGREEN, HEADGREEN. Defaults to `ALLGREEN`."', args=[d.arg(name='groupingStrategy', type=d.T.string)]),
          withGroupingStrategy(groupingStrategy): { groupingStrategy: groupingStrategy },
          '#withMaxEntriesToBuild':: d.fn(help='"(Number) Limit the number of queued pull requests requesting checks and workflow runs at the same time. Defaults to 5.\\nLimit the number of queued pull requests requesting checks and workflow runs at the same time. Defaults to `5`."', args=[d.arg(name='maxEntriesToBuild', type=d.T.integer)]),
          withMaxEntriesToBuild(maxEntriesToBuild): { maxEntriesToBuild: maxEntriesToBuild },
          '#withMaxEntriesToMerge':: d.fn(help='"(Number) Limit the number of queued pull requests requesting checks and workflow runs at the same time. Defaults to 5.\\nThe maximum number of PRs that will be merged together in a group. Defaults to `5`."', args=[d.arg(name='maxEntriesToMerge', type=d.T.integer)]),
          withMaxEntriesToMerge(maxEntriesToMerge): { maxEntriesToMerge: maxEntriesToMerge },
          '#withMergeMethod':: d.fn(help='"(String) Method to use when merging changes from queued pull requests. Can be one of: MERGE, SQUASH, REBASE. Defaults to MERGE.\\nMethod to use when merging changes from queued pull requests. Can be one of: MERGE, SQUASH, REBASE. Defaults to `MERGE`."', args=[d.arg(name='mergeMethod', type=d.T.string)]),
          withMergeMethod(mergeMethod): { mergeMethod: mergeMethod },
          '#withMinEntriesToMerge':: d.fn(help='"(Number) The minimum number of PRs that will be merged together in a group. Defaults to 1.\\nThe minimum number of PRs that will be merged together in a group. Defaults to `1`."', args=[d.arg(name='minEntriesToMerge', type=d.T.integer)]),
          withMinEntriesToMerge(minEntriesToMerge): { minEntriesToMerge: minEntriesToMerge },
          '#withMinEntriesToMergeWaitMinutes':: d.fn(help='"(Number) The time merge queue should wait after the first PR is added to the queue for the minimum group size to be met. After this time has elapsed, the minimum group size will be ignored and a smaller group will be merged. Defaults to 5.\\nThe time merge queue should wait after the first PR is added to the queue for the minimum group size to be met. After this time has elapsed, the minimum group size will be ignored and a smaller group will be merged. Defaults to `5`."', args=[d.arg(name='minEntriesToMergeWaitMinutes', type=d.T.integer)]),
          withMinEntriesToMergeWaitMinutes(minEntriesToMergeWaitMinutes): { minEntriesToMergeWaitMinutes: minEntriesToMergeWaitMinutes },
        },
        '#pullRequest':: d.obj(help='"(Block List, Max: 1) Require all commits be made to a non-target branch and submitted via a pull request before they can be merged. (see below for nested schema)\\nRequire all commits be made to a non-target branch and submitted via a pull request before they can be merged."'),
        pullRequest: {
          '#withDismissStaleReviewsOnPush':: d.fn(help='"(Boolean) New, reviewable commits pushed will dismiss previous pull request review approvals. Defaults to false.\\nNew, reviewable commits pushed will dismiss previous pull request review approvals. Defaults to `false`."', args=[d.arg(name='dismissStaleReviewsOnPush', type=d.T.boolean)]),
          withDismissStaleReviewsOnPush(dismissStaleReviewsOnPush): { dismissStaleReviewsOnPush: dismissStaleReviewsOnPush },
          '#withRequireCodeOwnerReview':: d.fn(help='"(Boolean) Require an approving review in pull requests that modify files that have a designated code owner. Defaults to false.\\nRequire an approving review in pull requests that modify files that have a designated code owner. Defaults to `false`."', args=[d.arg(name='requireCodeOwnerReview', type=d.T.boolean)]),
          withRequireCodeOwnerReview(requireCodeOwnerReview): { requireCodeOwnerReview: requireCodeOwnerReview },
          '#withRequireLastPushApproval':: d.fn(help='"(Boolean) Whether the most recent reviewable push must be approved by someone other than the person who pushed it. Defaults to false.\\nWhether the most recent reviewable push must be approved by someone other than the person who pushed it. Defaults to `false`."', args=[d.arg(name='requireLastPushApproval', type=d.T.boolean)]),
          withRequireLastPushApproval(requireLastPushApproval): { requireLastPushApproval: requireLastPushApproval },
          '#withRequiredApprovingReviewCount':: d.fn(help='"(Number) The number of approving reviews that are required before a pull request can be merged. Defaults to 0.\\nThe number of approving reviews that are required before a pull request can be merged. Defaults to `0`."', args=[d.arg(name='requiredApprovingReviewCount', type=d.T.integer)]),
          withRequiredApprovingReviewCount(requiredApprovingReviewCount): { requiredApprovingReviewCount: requiredApprovingReviewCount },
          '#withRequiredReviewThreadResolution':: d.fn(help='"(Boolean) All conversations on code must be resolved before a pull request can be merged. Defaults to false.\\nAll conversations on code must be resolved before a pull request can be merged. Defaults to `false`."', args=[d.arg(name='requiredReviewThreadResolution', type=d.T.boolean)]),
          withRequiredReviewThreadResolution(requiredReviewThreadResolution): { requiredReviewThreadResolution: requiredReviewThreadResolution },
        },
        '#requiredCodeScanning':: d.obj(help='"(Block List, Max: 1) Define which tools must provide code scanning results before the reference is updated. When configured, code scanning must be enabled and have results for both the commit and the reference being updated. Multiple code scanning tools can be specified. (see below for nested schema)\\nChoose which tools must provide code scanning results before the reference is updated. When configured, code scanning must be enabled and have results for both the commit and the reference being updated."'),
        requiredCodeScanning: {
          '#requiredCodeScanningTool':: d.obj(help='"(Block Set, Min: 1) Actions code scanning tools that are required. Multiple can be defined. (see below for nested schema)\\nTools that must provide code scanning results for this rule to pass."'),
          requiredCodeScanningTool: {
            '#withAlertsThreshold':: d.fn(help='"(String) The severity level at which code scanning results that raise alerts block a reference update. Can be one of: none, errors, errors_and_warnings, all.\\nThe severity level at which code scanning results that raise alerts block a reference update. Can be one of: `none`, `errors`, `errors_and_warnings`, `all`."', args=[d.arg(name='alertsThreshold', type=d.T.string)]),
            withAlertsThreshold(alertsThreshold): { alertsThreshold: alertsThreshold },
            '#withSecurityAlertsThreshold':: d.fn(help='"(String) The severity level at which code scanning results that raise security alerts block a reference update. Can be one of: none, critical, high_or_higher, medium_or_higher, all.\\nThe severity level at which code scanning results that raise security alerts block a reference update. Can be one of: `none`, `critical`, `high_or_higher`, `medium_or_higher`, `all`."', args=[d.arg(name='securityAlertsThreshold', type=d.T.string)]),
            withSecurityAlertsThreshold(securityAlertsThreshold): { securityAlertsThreshold: securityAlertsThreshold },
