          },
          '#withRequiredCodeScanningTool':: d.fn(help='"(Block Set, Min: 1) Actions code scanning tools that are required. Multiple can be defined. (see below for nested schema)\\nTools that must provide code scanning results for this rule to pass."', args=[d.arg(name='requiredCodeScanningTool', type=d.T.array)]),
